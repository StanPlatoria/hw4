<h1><%= @place["name"] %></h1>

<h2 class="mt-4 mb-3">My Entries</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% for entry in @entries %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-5">
  <% if session["user_id"] %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">
      New Entry
    </a>
  <% end %>

  <a href="/places" class="btn btn-outline-secondary">
    Back to All Places
  </a>
</div>